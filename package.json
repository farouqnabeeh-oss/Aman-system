{
  "name": "ems-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm exec prisma generate --schema=apps/api/prisma/schema.prisma",
    "db:migrate": "pnpm exec prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:seed": "pnpm --filter @ems/api run db:seed"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  },
  "devDependencies": {
    "prisma": "5.22.0",
    "turbo": "^1.13.0"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@9.0.0"
}