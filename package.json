{
  "name": "ems-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm exec prisma generate --schema=apps/portal/prisma/schema.prisma",
    "db:migrate": "pnpm exec prisma migrate deploy --schema=apps/portal/prisma/schema.prisma",
    "db:seed": "pnpm --filter portal run db:seed"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "5.22.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^25.6.0",
    "prisma": "5.22.0",
    "turbo": "^1.13.0"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@9.0.0"
}
