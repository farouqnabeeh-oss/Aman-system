{
  "name": "ems-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "npx prisma generate --schema=apps/api/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:seed": "pnpm --filter @ems/api run db:seed",
    "postinstall": "npm run db:generate"
  },
  "devDependencies": {
    "turbo": "^1.13.0"
  },
  "packageManager": "pnpm@9.0.0"
}