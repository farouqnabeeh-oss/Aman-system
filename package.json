{
  "name": "ems-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "npx prisma@5.13.0 generate --schema=apps/api/prisma/schema.prisma",
    "db:migrate": "npx prisma@5.13.0 migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:seed": "pnpm --filter @ems/api run db:seed"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "turbo": "^1.13.0"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@9.0.0"
}