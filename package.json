{
  "name": "ems-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @ems/api run db:generate",
    "db:migrate": "pnpm --filter @ems/api run db:migrate",
    "db:seed": "pnpm --filter @ems/api run db:seed",
    "db:studio": "pnpm --filter @ems/api run db:studio",
    "postinstall": "pnpm run db:generate"
  },
  "devDependencies": {
    "turbo": "^1.13.0"
  },
  "packageManager": "pnpm@9.0.0"
}
