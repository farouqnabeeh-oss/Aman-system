{
  "buildCommand": "pnpm exec prisma generate --schema=apps/api/prisma/schema.prisma && pnpm build --filter @ems/api",
  "functions": {
    "serverless.js": {
      "includeFiles": "apps/api/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/v1/(.*)", "destination": "/serverless.js" },
    { "source": "/api/(.*)", "destination": "/serverless.js" },
    { "source": "/", "destination": "/serverless.js" }
  ],
  "framework": null
}
