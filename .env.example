# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# For local development use SQLite:
DATABASE_URL="file:./dev.db"
# For Supabase PostgreSQL (production):
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-64-char-random-hex-access-secret
JWT_REFRESH_SECRET=your-64-char-random-hex-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000
API_PREFIX=api/v1

# ─── Email (Resend or SMTP) ───────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com
# Fallback: log emails to console in dev (set RESEND_API_KEY to 'mock')

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BUCKET=ems-files
# Local uploads folder (dev only — ignored in prod)
LOCAL_UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
AUTH_THROTTLE_LIMIT=5

# ─── Cors ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
